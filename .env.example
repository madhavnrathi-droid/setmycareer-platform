# Copy to .env and fill in. On Railway, set these as service variables instead.

# Free Groq API key — https://console.groq.com/keys
GROQ_API_KEY=

# LLM model id (Llama / Qwen / Mistral) — https://console.groq.com/docs/models
LLM_MODEL=llama-3.3-70b-versatile

# Whisper model for audio transcription
STT_MODEL=whisper-large-v3

# SQLite path. On Railway, mount a Volume and use e.g. /data/bloo.db
DB_PATH=bloo.db

# OpenRouter API key — unified access to Claude (Opus 4.8) + many models.
# https://openrouter.ai/keys ; choose a model slug at https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# --- Meeting integrations (optional) — Google Meet + Zoho Meeting -----------
# Without these, meetings import manually (paste link/transcript or upload the
# recording). With them, users get one-click Connect + (where available) auto pull.
# Public base URL of the deployment; register redirect URIs as
#   {OAUTH_REDIRECT_BASE}/api/integrations/{google|zoho}/callback
OAUTH_REDIRECT_BASE=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com

# --- Supabase (cloud backbone) ---------------------------------------------
# Direct Postgres connection string from Supabase → Project Settings → Database →
# "Connection string" → Transaction pooler (port 6543). Includes the DB password;
# bypasses RLS. Leave blank to run stateless (on-device) like before.
DATABASE_URL=
SUPABASE_URL=https://yntmpmvphlqypbmlevbd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Fireflies-grade meeting bot (Recall.ai) — optional --------------------
# A bot that auto-joins Zoom/Meet/Teams, records, and transcribes. Free dev key
# at https://recall.ai. Without it, meetings import manually (no breakage).
RECALL_API_KEY=
RECALL_BASE=https://us-east-1.recall.ai
RECALL_WEBHOOK_URL=

# --- Appwrite (cloud backend) — optional; when set, persistence uses Appwrite ---
# Create a project at cloud.appwrite.io, then an API key with the `databases` scope.
# Run scripts/setup_appwrite.py once to create the collections.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=setmycareer
